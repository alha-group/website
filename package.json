{
  "name": "middleman-template",
  "version": "2.0.0",
  "private": true,
  "description": "Another Middleman website",
  "scripts": {
    "dev": "webpack --mode development --watch --progress",
    "build": "webpack --mode production",
    "webfonts": "bemo-webfonts -s source/fonts/svg -f source/fonts -S source/stylesheets/variables/_icon-glyphs.scss",
    "start:proxy": "./proxy/proxy.js",
    "start:lambda": "netlify-lambda serve -c netlify.config.js functions/source",
    "build:lambda": "netlify-lambda build -c netlify.config.js functions/source",
    "lint": "yarn run eslint source/javascripts/*",
    "lint:autocorrect": "eslint source/javascripts/* --fix",
    "start": "concurrently \"npm run start:proxy\" \"npm run start:lambda\" \"npm run start:webpack\""
  },
  "author": "Cantiere Creativo s.r.l.",
  "main": "index.js",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.3.0",
    "@babel/preset-env": "^7.29.2",
    "animejs": "^3.0.1",
    "aos": "^2.3.4",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "bemo-sass": "damjack/bemo#master",
    "css-loader": "^7.1.2",
    "glob": "^7.1.2",
    "glob-loader": "^0.3.0",
    "import-glob": "^1.5.0",
    "jquery": "3.3.1",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "sass": "^1.86.0",
    "sass-loader": "^16.0.5",
    "slick-carousel": "^1.8.1",
    "style-loader": "^4.0.0",
    "svg-sprite-loader": "^6.0.11",
    "svgo": "^3.3.2",
    "svgo-loader": "^4.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-modernizr-loader": "^5.0.0"
  }
}
