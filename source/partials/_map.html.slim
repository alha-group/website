link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""
script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""

#map class="map__google" style="width: 100%; height: 640px; background: #ececec; position: relative; z-index: 1;"

javascript:
  (function() {
    var points = #{points};
    var map = L.map('map', {
      scrollWheelZoom: false,
      dragging: window.innerWidth > 480
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 20
    }).addTo(map);

    var bounds = L.latLngBounds();

    for (var i = 0; i < points.length; i++) {
      var elem = points[i];
      var marker = L.marker([elem.lat, elem.long]).addTo(map);
      marker.bindPopup("<div class='marker__info'><div class='marker__info__heading'><a href='" + elem.path + "'>" + elem.name + "</a></div><div class='marker__info__body'>" + elem.address + "</div></div>");
      bounds.extend([elem.lat, elem.long]);
    }

    map.fitBounds(bounds, { padding: [30, 30] });
  })();
